  </div>
  <div class="footer-legal">
    {% for line in site.footer.legal_lines %}
    {{ line }}{% if not loop.last %}<br>{% endif %}
    {% endfor %}
  </div>
</footer>

<script src="/assets/js/main.js"></script>
</body>
</html>
